# Environment variables and PATH — sourced by zsh/.zshrc_custom

# PATH
export PATH="${HOME}/scripts:${DOTFILES_DIR:-$HOME/workspace/dotfiles}/bin:${PATH}"
export PATH="/opt/homebrew/bin:${PATH}"
export PATH="$JAVA_HOME/bin:$PATH"
export PATH="$HOME/n/bin:$PATH"
export PATH="$GOPATH/bin:$PATH"
export PATH="${KREW_ROOT:-$HOME/.krew}/bin:$PATH"
export PATH="$PATH:/Applications/GoLand.app/Contents/MacOS"
export PATH="/opt/homebrew/opt/node@18/bin:$PATH"
export PATH="$GEM_HOME/bin:$PATH"

# General
export EDITOR=nvim
export DOCKER_DEFAULT_PLATFORM="linux/arm64"
export N_PREFIX="$HOME/n"
export GEM_HOME=~/.gem
export GOPATH=$(go env GOPATH)
export GOPRIVATE=github.com/hashicorp
export HUSKY=0
export HUSKY_SKIP_HOOKS=1

# Tool init
eval "$(/opt/homebrew/bin/brew shellenv)"
eval "$(zoxide init zsh)"
eval "$(direnv hook zsh)"
