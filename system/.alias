# General aliases — sourced by zsh/.zshrc_custom

# Shell
alias reload="exec zsh"

# Directory traversal
alias ..="cd .."
alias ...="cd ../.."
alias ....="cd ../../.."

# eza
alias ls='eza --icons -x -a --group-directories-first'
alias ll='eza --icons -a -l'
alias lt='eza --tree'
alias ltl='eza --tree -L'
alias lr='eza --recurse'

# Editor
alias vim="nvim"
alias vi="nvim"
alias v="nvim"

# Ripgrep
alias rg="rg --type-add 'gomod:go.mod' --type-add 'web:*.{html,css,js}'"

# Tmux
alias tmux="TERM=screen-256color-bce tmux"
alias mux="tmuxinator"

# UUID
alias uuidgen='uuidgen | tr "[:upper:]" "[:lower:]"'

# Git
alias gc="git checkout"
alias gria="git ria"
alias grial="git rial"
alias gcm="git checkout main 2>/dev/null || git checkout master"
alias glg="git log --graph --abbrev-commit --decorate --date=relative --format=format:'%C(bold blue)%h%C(reset) - %C(bold green)(%ar)%C(reset) %C(white)%s%C(reset) %C(dim white)- %an%C(reset)%C(bold yellow)%d%C(reset)' --all"
alias gcf="git commit --fixup HEAD"
alias gaf="git add . && gcf"
alias checkout='git checkout $(git branch --sort=-committerdate | fzf --border=rounded --margin=50,5,5,2)'
alias gaap="gapa"

# Kubernetes
alias kc=kubectl
alias k=kubectl

# Go
alias yaegi='rlwrap yaegi'

# Maven
alias mci="mvn clean install"
alias mcist="mvn clean install -DskipTests"

