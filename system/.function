# General functions — sourced by zsh/.zshrc_custom

# Directory helpers
mk() { mkdir -p "$@"; }
mkcd() { mkdir -p "$@" && cd "$@"; }
mkfile() { mkdir -p $(dirname "$1") && touch "$1"; }

# Archive
extract() { tar -xvf "$1"; }
compress() { tar -czvf "$1" "$2"; }

# Show 256 TERM colors
colors() {
  local X=$(tput op)
  local Y=$(printf %$((COLUMNS - 6))s)
  for i in {0..256}; do
    o=00$i
    echo -e ${o:${#o}-3:3} $(
      tput setaf $i
      tput setab $i
    )${Y// /=}$X
  done
}

# Print all aliases
aliases() { bat $HOME/workspace/dotfiles/system/.alias; }

# Throwaway Go project in a tmux session
tmpgo() {
  tempdir=$(mktemp -d)
  (cd "$tempdir" && go mod init "github.com/zalimeni/tempdir" && touch "main.go" && go mod tidy)
  echo "package main

import \"fmt\"

func main() {
  fmt.Println(\"Hello, World!\")
}
" > "$tempdir/main.go"
  tmux-sessionizer "$tempdir"
}

# Git clone shorthand
clone() { git clone git@github.com:${1}.git; }

# Git canary branch
make-canary() {
  CANARY_BRANCH="canary/$(git branch --show-current)"
  git branch -D ${CANARY_BRANCH} 2>/dev/null
  git checkout -b ${CANARY_BRANCH}
}

# Docker helpers
dcleanup() {
  docker image prune -a --filter "until=24h"
  docker container prune --filter "until=24h"
  docker volume prune --filter "label!=prod-tools-sso"
}

copy-from-docker() {
  DOCKER_IMAGE=$1
  SOURCE_FILEPATH=$2
  DEST_FILEPATH=$3
  DOCKER_PLATFORM=${4:-linux/amd64}
  docker cp $(docker create --name tmp-cp --platform ${DOCKER_PLATFORM} ${DOCKER_IMAGE}):${SOURCE_FILEPATH} ${DEST_FILEPATH} || true; docker rm tmp-cp
}

run-in-docker() {
  DOCKER_IMAGE=$1
  DOCKER_PLATFORM=${2}
  docker run -it --rm --platform ${DOCKER_PLATFORM} -v "$(pwd):/home/test" -w "/home/test" ${DOCKER_IMAGE} ${@:3}
}

# Maven
mvn-version-set() { mvn versions:set -DnewVersion=$1 -DgenerateBackupPoms=false; }

