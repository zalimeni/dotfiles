# Zsh-specific config — sourced by ~/.zshrc
# All env vars, aliases, and functions live in system/

# History
setopt HIST_IGNORE_ALL_DUPS
setopt HIST_IGNORE_SPACE
setopt HIST_SAVE_NO_DUPS
setopt HIST_FIND_NO_DUPS
setopt INC_APPEND_HISTORY
HISTSIZE=10000000
SAVEHIST=10000000

# Source dotfiles (order matters: env first, then aliases/functions)
# Resolve DOTFILES_DIR from this file's location (works whether sourced directly or via symlink)
(){
  local src="${(%):-%x}"
  [[ -L "$src" ]] && src="$(readlink -f "$src")"
  DOTFILES_DIR="$(cd "$(dirname "$src")/.." && pwd)"
}
for DOTFILE in "$DOTFILES_DIR"/system/.{env,alias,function,private_env,private_alias,private_function,work_env,work_alias,work_function}; do
  [[ -f "$DOTFILE" ]] && source "$DOTFILE"
done
