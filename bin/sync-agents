#!/usr/bin/env python3
"""
sync-agents: Translate agent files between Claude Code and opencode formats.

Reads .config/claude/agents/*.md, translates frontmatter fields that differ
between tools, and writes the results to .config/opencode/agents/ (and back).

The body content (below the --- delimiter) is copied verbatim in both directions.

Usage:
  sync-agents                 Forward sync: Claude -> opencode (default)
  sync-agents --from-opencode Reverse sync: opencode -> Claude
  sync-agents --check         Exit 1 if forward sync is out of date

Forward translation rules (Claude -> opencode):
  name, description   Copied as-is
  model               Dropped; agents use opencode's configured default model
  tools               Dropped; opencode has no fine-grained read-tool allowlist
  disallowedTools     Mapped to opencode tools: {write|edit|bash: false}
  skills              Dropped; opencode discovers skills via the skill tool
  mode                Inferred: agents with Bash/Task access -> "all", else "subagent"

Reverse translation rules (opencode -> Claude):
  name, description   Copied as-is
  tools (dict block)  Mapped back to Claude disallowedTools
  model, tools (str)  Preserved from the existing Claude file (never overwritten)
  skills              Preserved from the existing Claude file (never overwritten)
  body                Taken from the opencode file (reflects any edits made there)
"""

import sys
from pathlib import Path

DOTFILES = Path(__file__).resolve().parent.parent
CLAUDE_AGENTS = DOTFILES / ".config" / "claude" / "agents"
OPENCODE_AGENTS = DOTFILES / ".config" / "opencode" / "agents"

# Maps Claude disallowedTools names to opencode tool keys (and reverse)
TOOL_MAP = {
    "Write": "write",
    "Edit": "edit",
    "Bash": "bash",
}
REVERSE_TOOL_MAP = {v: k for k, v in TOOL_MAP.items()}


def parse_frontmatter(content: str) -> tuple[dict, str]:
    """Return (fields, body) from a markdown file with YAML frontmatter.

    Handles both flat key: value pairs and one level of indented sub-keys,
    which is used by the opencode tools block:

        tools:
          write: false
          edit: false
    """
    if not content.startswith("---\n"):
        return {}, content
    end = content.find("\n---\n", 4)
    if end == -1:
        return {}, content
    fm_str = content[4:end]
    body = content[end + 5:]

    fields: dict = {}
    current_key: str | None = None
    for line in fm_str.splitlines():
        if line.startswith("  ") and current_key is not None:
            # Indented continuation — sub-key of a dict-valued field
            if ": " in line:
                sub_k, sub_v = line.strip().split(": ", 1)
                if not isinstance(fields.get(current_key), dict):
                    fields[current_key] = {}
                fields[current_key][sub_k] = sub_v
        elif ": " in line and not line.startswith(" "):
            k, v = line.split(": ", 1)
            current_key = k.strip()
            fields[current_key] = v.strip()
        elif line.endswith(":") and not line.startswith(" "):
            current_key = line[:-1].strip()
            fields[current_key] = {}

    return fields, body


def forward_translate(src_path: Path, _dst: Path | None = None) -> str:
    """Return opencode-format content for a Claude agent file."""
    content = src_path.read_text()
    fields, body = parse_frontmatter(content)

    lines = ["---"]

    if "name" in fields:
        lines.append(f"name: {fields['name']}")
    if "description" in fields:
        lines.append(f"description: {fields['description']}")

    # Infer opencode mode from Claude tools allowlist.
    # Agents with Bash or Task access are primary-capable.
    claude_allowed = [t.strip() for t in str(fields.get("tools", "")).split(",") if t.strip()]
    lines.append("mode: all" if any(t in claude_allowed for t in ("Bash", "Task")) else "mode: subagent")

    # Map disallowedTools -> opencode tools block
    disallowed = [t.strip() for t in str(fields.get("disallowedTools", "")).split(",") if t.strip()]
    for t in disallowed:
        if t not in TOOL_MAP:
            print(f"WARNING: {src_path.name}: unmapped disallowedTool '{t}' — skipped", file=sys.stderr)
    opencode_disabled = sorted(TOOL_MAP[t] for t in disallowed if t in TOOL_MAP)
    if opencode_disabled:
        lines.append("tools:")
        for tool in opencode_disabled:
            lines.append(f"  {tool}: false")

    lines.append("---")
    return "\n".join(lines) + "\n" + body


def reverse_translate(oc_path: Path, cl_path: Path) -> str:
    """Return Claude-format content by merging opencode edits into the Claude file.

    The opencode file provides the updated body and tool restrictions.
    The existing Claude file's frontmatter is preserved verbatim — field order,
    formatting, and Claude-only fields (model, tools allowlist, skills) are all
    kept exactly as they are. Only fields that actually changed in opencode are
    updated in place.

    If no Claude file exists yet, a minimal frontmatter is generated.
    """
    oc_fields, oc_body = parse_frontmatter(oc_path.read_text())

    # Compute new disallowedTools from opencode tools block (set comparison
    # to avoid false positives from sort-order differences)
    oc_tools = oc_fields.get("tools", {})
    new_disabled_set: set[str] | None = None
    new_disabled_str: str | None = None
    if isinstance(oc_tools, dict):
        disabled = sorted(
            REVERSE_TOOL_MAP[k] for k, v in oc_tools.items()
            if v == "false" and k in REVERSE_TOOL_MAP
        )
        new_disabled_set = set(disabled)
        new_disabled_str = ", ".join(disabled)

    if not cl_path.exists():
        # No existing Claude file — generate minimal frontmatter
        lines = ["---"]
        for key in ("name", "description"):
            if key in oc_fields:
                lines.append(f"{key}: {oc_fields[key]}")
        if new_disabled_str:
            lines.append(f"disallowedTools: {new_disabled_str}")
        lines.append("---")
        return "\n".join(lines) + "\n" + oc_body

    cl_content = cl_path.read_text()
    cl_fields, _ = parse_frontmatter(cl_content)

    # Rebuild the Claude frontmatter line-by-line, preserving field order and
    # only updating lines whose values actually changed in opencode.
    fm_end = cl_content.find("\n---\n", 4)
    fm_lines = cl_content[4:fm_end].splitlines()

    new_fm: list[str] = []
    for line in fm_lines:
        if line.startswith(("name: ", "description: ")):
            key = line.split(": ", 1)[0]
            oc_val = oc_fields.get(key, "")
            new_fm.append(f"{key}: {oc_val}" if oc_val and oc_val != cl_fields.get(key) else line)
        elif line.startswith("disallowedTools: ") and new_disabled_set is not None:
            existing_set = {t.strip() for t in cl_fields.get("disallowedTools", "").split(",") if t.strip()}
            if new_disabled_set != existing_set:
                if new_disabled_str:
                    new_fm.append(f"disallowedTools: {new_disabled_str}")
                # else: tool restrictions removed in opencode — drop the line
            else:
                new_fm.append(line)  # identical set, preserve original string
        else:
            new_fm.append(line)

    return "---\n" + "\n".join(new_fm) + "\n---\n" + oc_body


def _sync(pairs: list[tuple[Path, Path]], translate_fn, check: bool) -> tuple[list[str], list[str]]:
    changed: list[str] = []
    errors: list[str] = []
    for src, dst in pairs:
        try:
            new_content = translate_fn(src, dst)
            if dst.exists() and dst.read_text() == new_content:
                continue
            changed.append(str(dst.relative_to(DOTFILES)))
            if not check:
                dst.write_text(new_content)
                print(f"  synced: {dst.relative_to(DOTFILES)}")
        except Exception as exc:
            errors.append(f"{src.name}: {exc}")
    return changed, errors


def main() -> None:
    check = "--check" in sys.argv
    from_opencode = "--from-opencode" in sys.argv

    if from_opencode:
        if check:
            print("WARNING: --check is not supported with --from-opencode; running sync anyway", file=sys.stderr)
        CLAUDE_AGENTS.mkdir(parents=True, exist_ok=True)
        pairs = [(src, CLAUDE_AGENTS / src.name) for src in sorted(OPENCODE_AGENTS.glob("*.md"))]
        changed, errors = _sync(pairs, reverse_translate, check=False)
    else:
        OPENCODE_AGENTS.mkdir(parents=True, exist_ok=True)
        pairs = [(src, OPENCODE_AGENTS / src.name) for src in sorted(CLAUDE_AGENTS.glob("*.md"))]
        changed, errors = _sync(pairs, forward_translate, check)

    if errors:
        for e in errors:
            print(f"ERROR: {e}", file=sys.stderr)
        sys.exit(1)

    if check and changed:
        for path in changed:
            print(f"OUT OF SYNC: {path}", file=sys.stderr)
        print(
            "\nRun 'bin/sync-agents' to regenerate opencode agents from Claude agents.",
            file=sys.stderr,
        )
        sys.exit(1)

    if not changed:
        print("  agents already in sync")


if __name__ == "__main__":
    main()
