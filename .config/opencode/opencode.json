{
  "$schema": "https://opencode.ai/config.json",

  // Model: using GitHub Copilot. After running `opencode /connect` and selecting
  // GitHub Copilot, run `/models` inside opencode to list available models and
  // confirm the exact IDs. Update these values if the IDs differ.
  "model": "github-copilot/gpt-5.4",
  "small_model": "github-copilot/gpt-5.3-codex",

  // Global instructions file — generated from the canonical Claude instructions
  // and symlinked by install_opencode() as ~/.config/opencode/AGENTS.md.
  "instructions": [
    "~/.config/opencode/AGENTS.md"
  ],

  "skills": {
    "paths": [
      "~/.claude/skills"
    ]
  },

  "plugin": [
    "opencode-handoff@0.3.2"
  ],

  "mcp": {
    // Gremlin graph database — requires a local gremlin-mcp binary and a
    // running Gremlin server at ws://localhost:8182/gremlin
    "gremlin": {
      "type": "local",
      "command": ["gremlin-mcp"],
      "environment": {
        "GREMLIN_URL": "ws://localhost:8182/gremlin"
      },
      "enabled": true
    },

    // Context7 — remote MCP for library documentation lookups
    // Requires CONTEXT7_KEY env var (set in system/.env or Claude Environments UI)
    "context7": {
      "type": "remote",
      "url": "https://mcp.context7.com/mcp",
      "headers": {
        "CONTEXT7_API_KEY": "{env:CONTEXT7_KEY}"
      },
      "enabled": true
    },

    // Jira — remote Atlassian MCP (disabled until credentials are configured)
    "jira": {
      "type": "remote",
      "url": "https://mcp.atlassian.com/v1/mcp",
      "enabled": false
    },

    // AWS Documentation — fetches official AWS docs via uvx (no credentials needed)
    "aws-documentation-mcp-server": {
      "type": "local",
      "command": ["uvx", "awslabs.aws-documentation-mcp-server@latest"],
      "environment": {
        "FASTMCP_LOG_LEVEL": "ERROR",
        "AWS_DOCUMENTATION_PARTITION": "aws"
      },
      "enabled": true
    },

    // gopls — Go language server as an MCP tool
    "gopls": {
      "type": "local",
      "command": ["gopls", "mcp"],
      "enabled": true
    },

    // GitHub — requires GITHUB_PERSONAL_ACCESS_TOKEN env var and Docker
    "github": {
      "type": "local",
      "command": [
        "docker", "run", "-i", "--rm",
        "-e", "GITHUB_PERSONAL_ACCESS_TOKEN={env:GITHUB_PERSONAL_ACCESS_TOKEN}",
        "ghcr.io/github/github-mcp-server"
      ],
      "enabled": false
    }
  },

  "lsp": {
    // gopls — Go language server (shared with the gopls MCP above)
    "gopls": {
      "command": ["gopls", "-remote=auto"]
    }
  },

  "experimental": {
    // Canonical Claude agent files use profile names; the generator resolves
    // them to concrete OpenCode model IDs from this map.
    "agentProfiles": {
      "balanced": "small_model",
      "heavy": "model"
    }
  }
}
